# CONFIGURATION
MUST_PORT=COM3

# MYSQL DATABASE
# MYSQL_HOST, MYSQL_DATABASE, MYSQL_USER, and MYSQL_PASSWORD are required.
MYSQL_HOST='db_ip'
MYSQL_DATABASE='db_name'
MYSQL_USER='db_user'
MYSQL_PASSWORD='user_password'

# Optional. Uses MySQL default port 3306 when missing or invalid.
MYSQL_PORT=3306

# DATA GATHERING
# Interval between inverter data requests, in seconds.
# Minimum: 10 seconds
# Maximum: 3600 seconds
# Invalid or missing values will use the default of 60 seconds.
DATA_GATHER_INTERVAL_SECONDS=60

# POWER MODE AUTO SWITCH
# Allowed values: true / false
ENABLE_AUTO_SWITCH=false

# Format: HH:MM
# 19:59 - False, 20:00 - True, 20:01 - True, 20:02 - True
AUTO_SWITCH_TARGET_TIME=20:00

# Target inverter energy mode
# Allowed values: SBU, SUB, UTI, SOL
AUTO_SWITCH_TARGET_MODE=SUB

# POWER MODE AUTO SWITCH — GRID OUTAGE
# Automatically switch the inverter mode when the electrical grid is unavailable.
# Allowed values: true / false
ENABLE_GRID_OUTAGE_AUTO_SWITCH=false

# Target inverter mode when the electrical grid is unavailable.
# Allowed values: SBU, SUB, UTI, SOL
GRID_OUTAGE_TARGET_MODE=SUB

# POWER MODE AUTO SWITCH — SOLAR PRIORITY
# Automatically switch from SUB when solar, battery, and load conditions
# remain suitable during the configured time window.
# Allowed values: true / false
ENABLE_SOLAR_AUTO_SWITCH=false

# Active time window. Start is inclusive and end is exclusive.
# Format: HH:MM
SOLAR_AUTO_SWITCH_START_TIME=12:00
SOLAR_AUTO_SWITCH_END_TIME=18:00

# Target inverter energy mode
# Allowed values: SBU, SUB, UTI, SOL
SOLAR_AUTO_SWITCH_TARGET_MODE=SBU

# Telemetry evaluation window and minimum data quality.
SOLAR_AUTO_SWITCH_LOOKBACK_MINUTES=10
SOLAR_AUTO_SWITCH_MIN_VALID_SAMPLES=8
SOLAR_AUTO_SWITCH_MIN_SAMPLE_SPAN_MINUTES=5

# Average telemetry thresholds used to confirm safe switching conditions.
SOLAR_AUTO_SWITCH_MIN_BATTERY_VOLTAGE=26.8
SOLAR_AUTO_SWITCH_MAX_LOAD_POWER=700
SOLAR_AUTO_SWITCH_MIN_PV_VOLTAGE=38.0

# Hard limits for the latest telemetry record. These prevent switching
# during a sudden load spike or a current battery/PV voltage drop.
SOLAR_AUTO_SWITCH_MIN_LATEST_BATTERY_VOLTAGE=26.4
SOLAR_AUTO_SWITCH_MAX_LATEST_LOAD_POWER=800
SOLAR_AUTO_SWITCH_MIN_LATEST_PV_VOLTAGE=35.0
